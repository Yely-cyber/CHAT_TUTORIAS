{
  "manifest_version": 3,
  "name": "Botón Chatbot UNSAAC",
  "version": "1.0",

  "content_scripts": [
    {
      "matches": [
        "https://in.unsaac.edu.pe/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "style.css"
      ]
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "chatbot.html",
        "chat.js",
        "chatbot.css",
        "imagenes/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}